{
  "name": "carbonwise",
  "version": "1.0.0",
  "private": true,
  "description": "CarbonWise — production-quality Carbon Footprint Awareness Platform",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
