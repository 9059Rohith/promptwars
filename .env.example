# Database — MongoDB Atlas connection string (include a database name, e.g. /carbonwise).
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/carbonwise?retryWrites=true&w=majority"

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# AI Sustainability Coach — set ONE provider key. Without any key the app falls
# back to a deterministic rule-based engine (fully functional offline).
# Groq is fast & free-tier friendly (OpenAI-compatible).
GROQ_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
